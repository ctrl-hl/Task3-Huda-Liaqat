{
  "info": {
    "_postman_id": "jwt-auth-api-collection",
    "name": "JWT Authentication REST API",
    "description": "Pre-configured requests for the Flask JWT Auth API.\n\n1. Run **Health Check** to verify the server.\n2. **Register** a user (or skip if already registered).\n3. **Login** — saves `access_token` and `refresh_token` to collection variables.\n4. Use protected routes with the saved access token.\n5. **Refresh Token** uses the refresh token variable.\n6. **Logout** blacklists the current access token.\n\nBase URL: `{{base_url}}` (default: http://127.0.0.1:5000)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:5000"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/health" },
            "description": "Public endpoint. Returns API and database status."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has success status', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('success');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"jane_doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"securepass1\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/auth/register" },
            "description": "Create a new user. Username: 3-30 alphanumeric/underscore. Password: min 8 chars with at least one number."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "",
                  "if (json.data && json.data.access_token) {",
                  "    pm.collectionVariables.set('access_token', json.data.access_token);",
                  "    console.log('access_token saved to collection variables');",
                  "}",
                  "",
                  "if (json.data && json.data.refresh_token) {",
                  "    pm.collectionVariables.set('refresh_token', json.data.refresh_token);",
                  "    console.log('refresh_token saved to collection variables');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"securepass1\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/auth/login" },
            "description": "Rate limited to 5 requests per minute per IP. Saves access_token and refresh_token to collection variables on success."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "",
                  "if (json.data && json.data.access_token) {",
                  "    pm.collectionVariables.set('access_token', json.data.access_token);",
                  "    console.log('access_token updated');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{refresh_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "url": { "raw": "{{base_url}}/api/auth/refresh" },
            "description": "Requires refresh token in Authorization header. Updates access_token collection variable."
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "url": { "raw": "{{base_url}}/api/auth/logout" },
            "description": "Requires access token. Blacklists the current JWT."
          },
          "response": []
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/user/profile" },
            "description": "Returns the logged-in user's profile. Requires access token."
          },
          "response": []
        },
        {
          "name": "Update Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"jane_smith\",\n  \"email\": \"jane.smith@example.com\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/user/profile" },
            "description": "Update username and/or email. At least one field required."
          },
          "response": []
        }
      ]
    }
  ]
}
